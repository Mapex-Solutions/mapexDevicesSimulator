{
  "name": "mapex-devices-simulator",
  "version": "1.0.0",
  "description": "Mapex Devices Simulator — local desktop tool to simulate IoT devices across HTTP, MQTT, LoRaWAN and Basics Station",
  "productName": "MapexDeviceSimulator",
  "author": "Thiago Anselmo <thiagoo.anselmoo@gmail.com>",
  "homepage": "https://github.com/Mapex-Solutions",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "quasar dev",
    "dev:electron": "npm run build:sidecar && quasar dev -m electron",
    "build": "quasar build",
    "build:electron": "npm run build:sidecar:all && quasar build -m electron",
    "build:sidecar": "node src-electron/sidecar/build-sidecar.mjs",
    "build:sidecar:all": "node src-electron/sidecar/build-sidecar.mjs --all",
    "postinstall": "quasar prepare",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest"
  },
  "dependencies": {
    "@quasar/extras": "^1.16.4",
    "axios": "^1.7.9",
    "pinia": "3.0.4",
    "quasar": "2.18.2",
    "vue": "3.5.18",
    "vue-i18n": "11.1.11",
    "vue-router": "4.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electron/packager": "^18.3.6",
    "@intlify/unplugin-vue-i18n": "^11.2.3",
    "@quasar/app-vite": "^2.6.0",
    "@sim/api": "*",
    "@sim/schema": "*",
    "@types/node": "^24.0.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "10.4.21",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "happy-dom": "^20.8.4",
    "typescript": "^5.9.2",
    "vite-plugin-checker": "0.10.2",
    "vitest": "^4.1.0",
    "vue-tsc": "3.0.5"
  },
  "engines": {
    "node": "^28 || ^26 || ^24",
    "npm": ">= 6.13.4"
  }
}
